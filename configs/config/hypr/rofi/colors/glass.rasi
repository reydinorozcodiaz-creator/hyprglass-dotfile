/* Glass Theme Colors */

* {
    /* Base colors with proper transparency for wayland */
    background:     rgba(30, 30, 46, 0.85);
    background-alt: rgba(49, 50, 68, 0.90);
    foreground:     #cdd6f4;
    selected:       rgba(137, 180, 250, 0.8);
    
    /* Ensure transparency is properly handled */
    transparency: "real";
}
