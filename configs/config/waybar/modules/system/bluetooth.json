{
  "custom/bluetooth": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/bluetooth_status.sh",
    "interval": 5,
    "on-click": "blueman-manager",
    "on-click-right": "~/.config/waybar/scripts/bluetooth_manager.sh toggle",
    "on-click-middle": "~/.config/waybar/scripts/bluetooth_manager.sh scan",
    "tooltip": true,
    "max-length": 20
  }
}
