{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",

  // ── Ventana de notificaciones ───────────────────────────────
  "fit-to-screen": false,               // ← desactivado
  "notification-window-width": 360,     // ancho fijo (px)
  "notification-window-height": 200,    // alto máximo (px)
  "notification-window-spacing": 8,     // espacio vertical entre notifs
  "notification-window-margin": 12,     // margen desde el borde de pantalla

  // ── Control Center ─────────────────────────────────────────
  "control-center-layer": "top",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "control-center-width": 500,
  "control-center-height": 600,

  // ── Contenido de las notificaciones ────────────────────────
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,

  // ── Tiempos y comportamiento ───────────────────────────────
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "hide-on-clear": false,
  "hide-on-action": true,
  "relative-timestamps": true,
  "keyboard-shortcuts": true,
  "script-fail-notify": true,

 
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    },
    "example-action-script": {
      "exec": "echo 'Do something actionable!'",
      "urgency": "Normal",
      "run-on": "action"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },


  "widgets": ["inhibitors", "title", "dnd", "notifications"],
  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "直",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && nmcli radio wifi on || nmcli radio wifi off'",
          "update_command": "sh -c '[[ $(nmcli radio wifi) == \"enabled\" ]] && echo true || echo false'"
        }
      ]
    }
  }
}
